{
  "name": "@voicyclaw/voicyclaw",
  "version": "0.1.0",
  "private": false,
  "description": "OpenClaw VoicyClaw channel plugin",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lyshen/VoicyClaw.git",
    "directory": "extensions/voicyclaw"
  },
  "homepage": "https://github.com/Lyshen/VoicyClaw/tree/main/extensions/voicyclaw",
  "bugs": {
    "url": "https://github.com/Lyshen/VoicyClaw/issues"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "voicyclaw",
    "voice"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "README.md",
    "index.ts",
    "openclaw.plugin.json",
    "src/channel.ts",
    "src/config.ts",
    "src/dispatch.ts",
    "src/gateway.ts",
    "src/protocol.ts",
    "src/runtime.ts",
    "src/socket-client.ts",
    "tsconfig.json"
  ],
  "dependencies": {
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "openclaw": "2026.3.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.1"
  },
  "scripts": {
    "lint": "biome check .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "voicyclaw",
      "label": "VoicyClaw",
      "selectionLabel": "VoicyClaw (Outbound Connector)",
      "detailLabel": "VoicyClaw",
      "docsPath": "/channels/voicyclaw",
      "docsLabel": "voicyclaw",
      "blurb": "Connect OpenClaw outward to a VoicyClaw service over WebSocket.",
      "aliases": [
        "voiceclaw"
      ],
      "order": 60
    }
  }
}
