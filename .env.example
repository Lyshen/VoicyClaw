NEXT_PUBLIC_VOICYCLAW_SERVER_URL=http://localhost:3001
VOICYCLAW_SERVER_URL=http://localhost:3001
VOICYCLAW_PUBLIC_SERVER_URL=
VOICYCLAW_SERVER_PORT=3001
VOICYCLAW_WEB_PORT=3000
VOICYCLAW_SQLITE_FILE=./apps/server/.data/voicyclaw.sqlite
BOT_NAME=Studio Claw
CHANNEL_ID=demo-room
BOT_ID=demo-clawbot
BOT_API_KEY=

# Optional: point the server to a custom provider YAML file.
# If empty, the server auto-loads config/providers.local.yaml when present.
VOICYCLAW_PROVIDER_CONFIG=

# Azure Speech TTS overrides
VOICYCLAW_AZURE_SPEECH_KEY=
VOICYCLAW_AZURE_SPEECH_REGION=
VOICYCLAW_AZURE_TTS_ENDPOINT=
VOICYCLAW_AZURE_TTS_VOICE=
VOICYCLAW_AZURE_TTS_SAMPLE_RATE=24000

# Google Cloud TTS overrides
VOICYCLAW_GOOGLE_TTS_ENDPOINT=
VOICYCLAW_GOOGLE_TTS_SERVICE_ACCOUNT_FILE=
VOICYCLAW_GOOGLE_TTS_SERVICE_ACCOUNT_JSON=
VOICYCLAW_GOOGLE_TTS_ACCESS_TOKEN=
VOICYCLAW_GOOGLE_TTS_API_KEY=
VOICYCLAW_GOOGLE_TTS_VOICE=
VOICYCLAW_GOOGLE_TTS_SAMPLE_RATE=24000
